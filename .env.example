PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/haratech_main?schema=public"

JWT_ACCESS_SECRET="change-me-access"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_REFRESH_TTL="7d"

API_KEY_PEPPER="change-me-pepper"
DOWNLOAD_BASE_URL="https://downloads.example.com"
DOWNLOAD_URL_SIGNING_SECRET="change-me-signing-secret"
DOWNLOAD_TTL_SECONDS=300
DOWNLOAD_RATE_LIMIT_WINDOW_SECONDS=3600
DOWNLOAD_RATE_LIMIT_KEY_MAX=20
DOWNLOAD_RATE_LIMIT_IP_MAX=60
# Optional: JSON array for global artifact catalog auto-seed on backend startup.
# Example: [{"version":"v1.0.0","platform":"darwin","arch":"arm64","filename":"cpp-fast-config-v1.0.0-darwin-arm64.tar.gz","objectKey":"cpp-fast-config/v1.0.0/darwin-arm64/cpp-fast-config.tar.gz","sha256":"<sha256>","size":1830240,"status":"ACTIVE"}]
ARTIFACT_CATALOG_SEED_JSON=

# Optional for CORS if needed in browser-direct calls
CORS_ORIGIN="http://localhost:3000"
